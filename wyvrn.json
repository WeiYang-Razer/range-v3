{
  "name": "range-v3",
  "version": "0.12.0.0",
  "schemaVersion": 2,
  "kind": "HeaderOnlyLib",
  "description": "Range library (basis of C++20 ranges)",
  "dependencies": {},
  "build": {
    "system": "cmake",
    "configs": [
      "Debug",
      "Release",
      "RelWithDebInfo",
      "MinSizeRel"
    ],
    "configure": [
      "-DRANGE_V3_DOCS=OFF",
      "-DRANGE_V3_TESTS=OFF",
      "-DRANGE_V3_EXAMPLES=OFF",
      "-DRANGE_V3_PERF=OFF",
      "-DRANGE_V3_HEADER_CHECKS=OFF",
      "-DRANGE_V3_INSTALL=ON"
    ],
    "installDir": "install"
  }
}
